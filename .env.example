# Variables de entorno — Prompt Engineering Landing
# Copia este archivo como .env y rellena los valores reales

# ── Configuración general ──────────────────────────────────────
VITE_BOOK_URL=ebook.nelsonramos.cl
VITE_PRICE=9.99
VITE_AMAZON_LINK="https://amazon.com/tu-libro"

# ── SMTP — envío de email con PDF adjunto ─────────────────────
# El PDF (public/assets/primer_capitulo_gratis.pdf) se adjunta
# automáticamente al email que recibe el usuario.
VITE_EMAIL_HOST=mail.nelsonramos.cl
VITE_EMAIL_PORT=587
VITE_EMAIL_USER=contacto@nelsonramos.cl
VITE_EMAIL_PASS=tu_password_aqui
