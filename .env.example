# Variables de entorno — Prompt Engineering Landing

# ──────────────────────────────────────────────────
# frontend Vite (públicas, prefijo VITE_)
# ──────────────────────────────────────────────────
VITE_BOOK_URL=ebook.nelsonramos.cl
VITE_PRICE=9.99
VITE_AMAZON_LINK="https://amazon.com/tu-libro"

# URL pública del PDF para incluir como enlace en el cuerpo del email
VITE_PDF_URL=https://tu-dominio.com/assets/primer_capitulo_gratis.pdf

# ──────────────────────────────────────────────────
# EmailJS — https://www.emailjs.com/
# Cuenta gratuita: 200 emails/mes sin tarjeta de crédito
#
# Pasos para configurar:
# 1. Crear cuenta en emailjs.com
# 2. Ir a "Email Services" → conectar Gmail u otro proveedor
# 3. Ir a "Email Templates" → crear template con estos parámetros:
#    - {{to_email}}    → destinatario (el email que ingresó el usuario)
#    - {{pdf_url}}     → enlace de descarga del PDF
#    - {{amazon_link}} → enlace de compra en Amazon
# 4. Copiar los IDs correspondientes aquí:
# ──────────────────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# Configuración SMTP (para futuros servicios de backend/integración nodemailer)
EMAIL_HOST=mail.nelsonramos.cl
EMAIL_PORT=587
EMAIL_USER=contacto@nelsonramos.cl
EMAIL_PASS=tu_password_aqui

