VITE_BOOK_URL=ebook.nelsonramos.cl
VITE_PRICE=9.99
VITE_AMAZON_LINK="https://amazon.com/"

# EmailJS — obtén estos valores en https://www.emailjs.com/
# 1. Crea una cuenta gratuita (200 emails/mes gratis)
# 2. Conecta un servicio de email (Gmail, Gmail OAuth, SendGrid, etc.)
# 3. Crea un template con los parámetros: to_email, pdf_url, amazon_link
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# URL pública del PDF (para incluir en el cuerpo del email)
# En desarrollo usa la ruta local; en producción usa tu dominio real
VITE_PDF_URL=https://ebook.nelsonramos.cl/assets/primer_capitulo_gratis.pdf

# Configuración SMTP (referencia para futuros servicios de backend o integración)
EMAIL_HOST=mail.nelsonramos.cl
EMAIL_PORT=587
EMAIL_USER=contacto@nelsonramos.cl
EMAIL_PASS=
